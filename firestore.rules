rules_version = '2';

// ──────────────────────────────────────────────────────────────
// "오늘의 우리" Firestore 보안 규칙
// 핵심: 블라인드 리빌 무결성 = "내가 제출해야 상대 답을 읽을 수 있다"
// ──────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }

    // 커플 멤버 여부(단일 문서 접근용). 멤버십은 couples.memberUids 배열.
    function isCoupleMember(coupleId) {
      return authed()
        && exists(/databases/$(database)/documents/couples/$(coupleId))
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
    }

    function myResponseExists(coupleId, dateKey) {
      return exists(/databases/$(database)/documents/coupleAnswers/$(coupleId)/days/$(dateKey)/responses/$(request.auth.uid));
    }

    // ── 사용자: 본인만 ──
    match /users/{uid} {
      allow read, write: if authed() && request.auth.uid == uid;
      match /entries/{dateKey} {
        allow read, write: if authed() && request.auth.uid == uid;
      }
    }

    // ── 질문 풀 / 스케줄: 읽기 전용 ──
    match /questions/{questionId} {
      allow read: if authed();
      allow write: if false;
    }
    match /questionSchedule/{dateKey} {
      allow read: if authed();
      allow write: if false;
    }

    // ── 커플(멤버십 = memberUids 배열; get·query 모두 지원) ──
    match /couples/{coupleId} {
      allow read:   if authed() && request.auth.uid in resource.data.memberUids;
      allow create: if authed() && request.auth.uid in request.resource.data.memberUids;
      allow update: if authed() && request.auth.uid in resource.data.memberUids;
      allow delete: if false;
    }

    // ── 커플 일별 공유 답변 ──
    match /coupleAnswers/{coupleId}/days/{dateKey} {
      allow read, write: if isCoupleMember(coupleId);

      // ★ 블라인드 리빌 게이트 ★
      match /responses/{memberUid} {
        // 작성: 본인 것만
        allow create: if isCoupleMember(coupleId) && memberUid == request.auth.uid;
        // 읽기: 내 답은 항상 / 상대 답은 "내가 이미 제출한 경우"에만
        allow read: if isCoupleMember(coupleId) && (
          memberUid == request.auth.uid ||
          myResponseExists(coupleId, dateKey)
        );
        // 수정·삭제: 본인 것만
        allow update, delete: if isCoupleMember(coupleId) && memberUid == request.auth.uid;
      }
    }

    // ── 초대코드: capability 패턴(코드 docId 를 아는 사람만) ──
    match /coupleInvites/{code} {
      allow create: if authed() && request.resource.data.createdByUid == request.auth.uid;
      allow read:   if authed();   // 짧은 만료시간으로 보호
      allow update: if authed();   // 수락 시 used 처리
      allow delete: if authed() && resource.data.createdByUid == request.auth.uid;
    }
  }
}
